#!/bin/bash
# craby â€” cliente de linha de comando do Craby (Crab Companion)
set -euo pipefail

S="http://localhost:4923"
TOKEN_FILE="$HOME/Library/Application Support/Craby/token"

usage() {
  cat <<'EOF'
craby â€” fale com o seu caranguejo đŸ¦€

uso:
  craby status                          estado atual (JSON)
  craby working|done|attention|idle     marca estado (projeto = pasta atual)
  craby ask "pergunta" "op A" "op B"    mĂºltipla escolha no balĂ£o (imprime a escolhida)
  craby input "pergunta"                texto livre no balĂ£o (imprime a resposta)
  craby answer <allow|deny|ask|opt:N|txt:...>   responde o balĂ£o atual
  craby celebrate ["texto"]             confete + toast (ex.: apĂ³s git push)
  craby event <fonte> <estado> [detalhe] [url]   evento estruturado
  craby watch <id> <alive|dead|gone> [label] [url]   vigĂ­lia
  craby quit                            encerra o app
EOF
}

[ $# -ge 1 ] || { usage; exit 1; }
cmd=$1
shift || true
proj=$(basename "$PWD" | jq -sRr @uri)

case "$cmd" in
  status)
    curl -s -m 2 "$S/status" | jq .
    ;;
  working|done|attention|idle)
    curl -s -m 2 "$S/$cmd?session=craby-cli&project=$proj" && echo
    ;;
  ask)
    [ $# -ge 3 ] || { echo "erro: craby ask \"pergunta\" \"op A\" \"op B\" [...]" >&2; exit 1; }
    q=$1
    shift
    opts_json=$(printf '%s\n' "$@" | jq -R . | jq -cs .)
    resp=$(jq -nc --arg d "$q" --argjson o "$opts_json" \
      '{title:"[cli] đŸ¦€", detail:$d, urgent:false, options:$o, input:null}' \
      | curl -s --max-time 90 -X POST -H 'Content-Type: application/json' -d @- "$S/ask")
    case "$resp" in
      opt:*)
        i=$(( ${resp#opt:} + 1 ))
        echo "${!i}"
        ;;
      *) echo "$resp" ;;
    esac
    ;;
  input)
    [ $# -ge 1 ] || { echo "erro: craby input \"pergunta\"" >&2; exit 1; }
    resp=$(jq -nc --arg d "$1" \
      '{title:"[cli] đŸ¦€", detail:$d, urgent:false, options:null, input:true}' \
      | curl -s --max-time 120 -X POST -H 'Content-Type: application/json' -d @- "$S/ask")
    case "$resp" in
      txt:*) echo "${resp#txt:}" ;;
      *) echo "$resp" ;;
    esac
    ;;
  event)
    [ $# -ge 2 ] || { echo "erro: craby event <fonte> <estado> [detalhe] [url]" >&2; exit 1; }
    curl -s -m 2 --get \
      --data-urlencode "source=$1" --data-urlencode "state=$2" \
      --data-urlencode "session=cli-$1" --data-urlencode "project=$(basename "$PWD")" \
      --data-urlencode "detail=${3:-}" --data-urlencode "url=${4:-}" \
      "$S/event" && echo
    ;;
  watch)
    [ $# -ge 2 ] || { echo "erro: craby watch <id> <alive|dead|gone> [label] [url]" >&2; exit 1; }
    curl -s -m 2 --get \
      --data-urlencode "id=$1" --data-urlencode "status=$2" \
      --data-urlencode "label=${3:-$1}" --data-urlencode "url=${4:-}" \
      --data-urlencode "source=cli" \
      "$S/watch" && echo
    ;;
  celebrate)
    curl -s -m 2 --get --data-urlencode "text=${1:-}" "$S/celebrate" && echo
    ;;
  answer)
    [ $# -ge 1 ] || { echo "erro: craby answer <allow|deny|ask|opt:N|txt:...>" >&2; exit 1; }
    tok=$(cat "$TOKEN_FILE" 2>/dev/null || true)
    curl -s -m 2 "$S/answer/$1?token=$tok" && echo
    ;;
  quit)
    tok=$(cat "$TOKEN_FILE" 2>/dev/null || true)
    curl -s -m 2 "$S/quit?token=$tok" && echo
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
